# Local image after `make all`: places binary + data under /opt/omnifin and includes curl for compose healthcheck.
FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*
COPY build/omnifin /opt/omnifin/omnifin
COPY build/data /opt/omnifin/data
EXPOSE 8056 8057
CMD ["/opt/omnifin/omnifin", "-data", "/data"]
