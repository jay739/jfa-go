{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities granted to all Omnifin Desktop windows",
  "windows": ["main", "*"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "core:app:default",
    "opener:default",
    "opener:allow-open-url"
  ]
}
