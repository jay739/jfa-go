{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omnifin",
  "version": "0.1.0",
  "identifier": "dev.jay739.omnifin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1430"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "appimage", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Native desktop client for an Omnifin server",
    "longDescription": "Omnifin Desktop is a native client window for a self-hosted Omnifin server. Point it at your server URL once and it becomes the front door to your Jellyfin/arr user management.",
    "publisher": "Jayakrishna Konda",
    "homepage": "https://github.com/jay739/omnifin",
    "linux": {
      "deb": {
        "section": "utils"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
